generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  PROFESIONAL
  ADMIN
}

enum ServiceRequestStatus {
  ACTIVA
  AGENDADA
  COMPLETADA
  CANCELADA
}

enum QuoteStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum JobStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADO
  CANCELADO
}

enum JobPaymentStatus {
  PENDIENTE
  RETENIDO
  LIBERADO
  REEMBOLSADO
}

enum PaymentStatus {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum BadgeType {
  VERIFICADO
  TOP_RATED
  EXPERTO
  NUEVO_TALENTO
}

enum NotificationType {
  SOLICITUD
  PRESUPUESTO
  MENSAJE
  PAGO
  CALIFICACION
  BADGE
  DISPUTA
  SISTEMA
}

enum DisputeStatus {
  ABIERTA
  EN_REVISION
  RESUELTA
  CERRADA
}

model User {
  id                    String           @id @default(uuid()) @db.Uuid
  email                 String           @unique
  phone                 String           @unique
  passwordHash          String
  role                  Role
  isActive              Boolean          @default(true)
  deactivationReason    String?
  deactivatedAt         DateTime?
  isEmailVerified       Boolean          @default(false)
  isIdentityVerified    Boolean          @default(false)
  otpCode               String?
  otpExpiry             DateTime?
  otpAttempts           Int              @default(0)
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  clientProfile         ClientProfile?
  professionalProfile   ProfessionalProfile?
  serviceRequestsAsClient ServiceRequest[] @relation("ClientRequests")
  quotesAsProfessional  Quote[]          @relation("ProfessionalQuotes")
  jobsAsClient          Job[]            @relation("ClientJobs")
  jobsAsProfessional    Job[]            @relation("ProfessionalJobs")
  messages              Message[]
  badges                Badge[]
  reviewsGiven          Review[]         @relation("ReviewsGiven")
  reviewsReceived       Review[]         @relation("ReviewsReceived")
  notifications         Notification[]
  disputesOpened        Dispute[]        @relation("DisputesOpenedBy")
  aiTrainingEvents      AiTrainingEvent[]
  portfolioPhotos       PortfolioPhoto[]
  npsResponses          NpsResponse[]

  @@map("users")
}

model ClientProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  name      String
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model ProfessionalProfile {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  name             String
  bio              String?  @db.VarChar(300)
  specialties      String[] @default([])
  hourlyRate       Decimal  @db.Decimal(10, 2)
  coverageRadiusKm Int      @default(5)
  avgRating        Decimal  @default(0) @db.Decimal(3, 2)
  aiScore          Float    @default(0)
  reviewCount      Int      @default(0)
  badges           String[] @default([])
  totalJobs        Int      @default(0)
  verifiedBadge    Boolean  @default(false)
  verificationStatus String @default("PENDIENTE")
  verificationNotes String?
  onboardingCompleted Boolean @default(false)
  onboardingSteps  Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("professional_profiles")
}

model Category {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  iconUrl         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  serviceRequests ServiceRequest[]

  @@map("categories")
}

model ServiceRequest {
  id          String               @id @default(uuid()) @db.Uuid
  clientId    String               @db.Uuid
  categoryId  String               @db.Uuid
  description String
  photosUrls  String[]             @default([])
  preferredDateTime DateTime?
  preferredSchedule String?
  locationLabel String?
  locationLat Float?
  locationLng Float?
  locationAccuracy Float?
  status      ServiceRequestStatus @default(ACTIVA)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  client      User                 @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  category    Category             @relation(fields: [categoryId], references: [id])
  quotes      Quote[]
  messages    Message[]
  aiTrainingEvents AiTrainingEvent[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@map("service_requests")
}

model Quote {
  id             String      @id @default(uuid()) @db.Uuid
  requestId      String      @db.Uuid
  professionalId String      @db.Uuid
  amountCop      Float
  estimatedHours Float
  message        String
  status         QuoteStatus @default(PENDIENTE)
  expiresAt      DateTime
  createdAt      DateTime    @default(now())
  request        ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  professional   User        @relation("ProfessionalQuotes", fields: [professionalId], references: [id], onDelete: Cascade)
  job            Job?

  @@index([requestId])
  @@index([professionalId])
  @@index([status])
  @@map("quotes")
}

model Job {
  id               String           @id @default(uuid()) @db.Uuid
  quoteId          String           @unique @db.Uuid
  clientId         String           @db.Uuid
  professionalId   String           @db.Uuid
  status           JobStatus        @default(PENDIENTE)
  paymentStatus    JobPaymentStatus @default(PENDIENTE)
  escrowReleaseAt  DateTime
  clientConfirmed  Boolean          @default(false)
  npsReminderSent  Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  quote            Quote            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  client           User             @relation("ClientJobs", fields: [clientId], references: [id], onDelete: Cascade)
  professional     User             @relation("ProfessionalJobs", fields: [professionalId], references: [id], onDelete: Cascade)
  payment          Payment?
  reviews          Review[]
  dispute          Dispute?
  npsResponses     NpsResponse[]

  @@index([clientId])
  @@index([professionalId])
  @@index([paymentStatus])
  @@index([status])
  @@map("jobs")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  jobId                 String        @unique @db.Uuid
  stripePaymentIntentId String
  amountCop             Float
  commissionCop         Float
  netProfessionalCop    Float
  status                PaymentStatus @default(PENDIENTE)
  createdAt             DateTime      @default(now())
  job                   Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payments")
}

model Message {
  id        String         @id @default(uuid()) @db.Uuid
  requestId String         @db.Uuid
  senderId  String         @db.Uuid
  content   String
  createdAt DateTime       @default(now())
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    User           @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([senderId])
  @@map("messages")
}

model Review {
  id                 String   @id @default(uuid()) @db.Uuid
  jobId              String   @db.Uuid
  reviewerId         String   @db.Uuid
  reviewedId         String   @db.Uuid
  rating             Int
  subcategoryRatings Json
  comment            String   @db.VarChar(400)
  createdAt          DateTime @default(now())
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewer           User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewed           User     @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)

  @@unique([jobId, reviewerId])
  @@index([reviewedId])
  @@index([createdAt])
  @@map("reviews")
}

model Badge {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  type      BadgeType
  awardedAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("badges")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Dispute {
  id          String       @id @default(uuid()) @db.Uuid
  jobId        String       @unique @db.Uuid
  openedBy     String       @db.Uuid
  reason       String
  description  String
  status       DisputeStatus @default(ABIERTA)
  resolution   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  openedByUser User         @relation("DisputesOpenedBy", fields: [openedBy], references: [id], onDelete: Cascade)

  @@index([openedBy])
  @@index([status])
  @@map("disputes")
}

model AiTrainingEvent {
  id             String         @id @default(uuid()) @db.Uuid
  professionalId String         @db.Uuid
  requestId      String         @db.Uuid
  action         String
  outcome        String
  createdAt      DateTime       @default(now())
  professional   User           @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  request        ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([professionalId, createdAt])
  @@index([requestId])
  @@map("ai_training_events")
}

model PortfolioPhoto {
  id             String   @id @default(uuid()) @db.Uuid
  professionalId String   @db.Uuid
  photoUrl       String
  description    String?
  createdAt      DateTime @default(now())
  professional   User     @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, createdAt])
  @@map("portfolio_photos")
}

model NpsResponse {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @db.Uuid
  userId    String   @db.Uuid
  score     Int
  comment   String?  @db.VarChar(300)
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId, createdAt])
  @@map("nps_responses")
}
